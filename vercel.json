{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Content-Security-Policy", "value": "script-src 'self' 'unsafe-eval' 'unsafe-inline' https://app.midtrans.com https://app.sandbox.midtrans.com https://*.midtrans.com blob: *; object-src 'none';" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?<slug>[^.]+)\\.cukurship\\.id"
        }
      ],
      "destination": "/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/affiliate-commissions",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/tenant-health-check",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/cleanup-bot-sessions",
      "schedule": "0 2 * * *"
    }
  ]
}
